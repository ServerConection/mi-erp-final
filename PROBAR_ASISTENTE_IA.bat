@echo off
REM Prueba el cerebro IA del asistente a traves del TUNEL (como lo hara Render).
cd /d "%~dp0"
node -e "(async()=>{const fs=require('fs');const SYS='Eres el Asistente del ERP de Novonet y Velsa (ventas de internet en Ecuador). Responde SIEMPRE en espanol, claro y breve. Usa UNICAMENTE los DATOS JSON entregados (cifras reales del ERP). NUNCA inventes cifras ni nombres. Glosario: ventas subidas=CRM; ingresos jotform=Jot; venta seguimiento=jot menos ventas del dia; activas=instalaciones; descartes=leads descartados. Usa *negritas* y listas numeradas en rankings.';const snap={fecha_actual_ecuador:'2026-06-10',periodos:{HOY:{NOVONET:{resumen:{leads_creados:42,ventas_crm_subidas:9,ingresos_jotform:11,ventas_del_dia:6,venta_seguimiento:5,activas:4,descartes:12},top_ventas_subidas_por_asesor:[{nombre:'JEANNETH PEREZ',cantidad:3},{nombre:'DANNY LOPEZ',cantidad:2}],top_descartes_por_asesor:[{nombre:'CARLOS RUIZ',cantidad:5},{nombre:'ANA VEGA',cantidad:3}]},VELSA:{resumen:{leads_creados:30,ventas_crm_subidas:5,ingresos_jotform:7,ventas_del_dia:3,venta_seguimiento:4,activas:2,descartes:8},top_ventas_subidas_por_asesor:[{nombre:'LUIS MORA',cantidad:2}],top_descartes_por_asesor:[{nombre:'JORGE DIAZ',cantidad:4}]}}}};const preg='quien va ganando hoy en ventas entre las dos empresas y quien tiene mas descartes en general?';const t0=Date.now();try{const r=await fetch('http://8.tcp.ngrok.io:15149/api/chat',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'llama3',stream:false,options:{temperature:0.2,num_ctx:8192},messages:[{role:'system',content:SYS},{role:'user',content:'DATOS DEL ERP (JSON):\n'+JSON.stringify(snap)+'\n\nPREGUNTA: '+preg}]}),signal:AbortSignal.timeout(90000)});const d=await r.json();fs.writeFileSync('prueba_ia.txt','HTTP '+r.status+' | '+((Date.now()-t0)/1000).toFixed(1)+'s\n\n'+(d.message&&d.message.content?d.message.content:JSON.stringify(d).slice(0,500)));}catch(e){fs.writeFileSync('prueba_ia.txt','ERROR: '+e.message)}})()"
echo Resultado en prueba_ia.txt
timeout /t 3 >nul
