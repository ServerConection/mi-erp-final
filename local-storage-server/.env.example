# Puerto donde escucha este servicio en tu servidor local
PORT=4500

# Clave secreta compartida con el backend principal (Render).
# Genera una larga y aleatoria, ej: openssl rand -hex 32
API_KEY=CAMBIA_ESTO_POR_UNA_CLAVE_LARGA_Y_ALEATORIA

# Carpeta donde se guardan físicamente los archivos en este servidor
STORAGE_DIR=./storage
